{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yaml,yml,md}\"",
    "kimi-proxy": "node openrouter-kimi-crucible-proxy.js",
    "test:kimi": "node test-kimi-direct.js"
  },
  "private": true,
  "devDependencies": {
    "lightningcss": "1.31.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.1",
    "@vitest/coverage-v8": "^3.2.1"
  }
}
