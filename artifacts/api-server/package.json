    "drizzle-orm": "catalog:",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^1.2.0",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "openai": "^4.100.0",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
